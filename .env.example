# 算法可视化平台 - AI 助手配置示例
#
# 注意：
# 1. 此文件可以提交到 GitHub
# 2. 不要在此文件中写入真实 API Key
# 3. 本地配置请使用 .env.local（已在 .gitignore 中）

# ============================================
# 方式一：本地知识库（默认，推荐用于演示）
# ============================================
VITE_AI_PROVIDER=local
# 离线可用，无需 API Key，适合课程设计答辩演示

# ============================================
# 方式二：直接配置 API Key（仅限本地测试）
# ============================================
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=你的API密钥
# VITE_AI_API_BASE_URL=https://api.openai.com/v1
# VITE_AI_MODEL=gpt-3.5-turbo

# ============================================
# DeepSeek 配置示例（OpenAI 兼容格式）
# ============================================
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_AI_API_BASE_URL=https://api.deepseek.com
# VITE_AI_MODEL=deepseek-chat

# ============================================
# 智谱 GLM 配置示例（OpenAI 兼容格式）
# ============================================
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=你的智谱API密钥
# VITE_AI_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# VITE_AI_MODEL=glm-4

# ============================================
# 方式三：后端代理（推荐用于生产环境）
# ============================================
# VITE_AI_PROVIDER=proxy
# VITE_AI_PROXY_URL=http://localhost:3001/api/ai-chat
# API Key 由后端服务器保管，前端不暴露

# ============================================
# 使用说明
# ============================================
# 1. 复制此文件为 .env.local
# 2. 取消注释并修改对应配置
# 3. 重启开发服务器：npm run dev
#
# 详见 docs/AI_ASSISTANT.md
